# Larry Agent Environment Variables
# ===================================

# HuggingFace Token (for downloading models)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=
HUGGINGFACE_TOKEN=

# Web search keys (the agentic web_search tool auto-picks tavily > brave >
# keyless duckduckgo, so NEITHER of these is required — DuckDuckGo works with
# no key. Fill them for higher-quality results.)
# Brave Search: free tier at https://brave.com/search/api/
BRAVE_API_KEY=
# Tavily: free tier at https://app.tavily.com/  (also enables web_answer)
TAVILY_API_KEY=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

# GitHub (for GitHub MCP server)
GITHUB_TOKEN=

# Telegram Bot (optional) — @Local_Larry_Untamed_bot
TELEGRAM_BOT_TOKEN=8905413271:AAHp3prLJahTWTwV4u_oeXVSxIFCbES8-Bo

# Ollama
OLLAMA_HOST=http://localhost:11434

# OpenRouter API (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# RAG Backend (chroma or postgres)
RAG_BACKEND=chroma

# Disable Telemetry
ANONYMIZED_TELEMETRY=False
CHROMA_TELEMETRY=False
POSTHOG_DISABLED=1
DO_NOT_TRACK=1
TF_ENABLE_ONEDNN_OPTS=0
TF_CPP_MIN_LOG_LEVEL=2